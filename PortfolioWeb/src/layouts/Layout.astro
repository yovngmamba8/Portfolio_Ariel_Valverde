---
import "../styles/global.css";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen bg-linear-to-tr from-slate-950 via-blue-950 to-black bg-no-repeat bg-fixed
				px-4 py-8 md:py-12"
  >
    <div
      class="w-full max-w-7xl mx-auto bg-slate-900 rounded-2xl shadow-2xl border border-slate-800"
    >
      <div
        class="bg-slate-950/80 px-4 py-3 border-b border-slate-800 flex gap-2"
      >
        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
      </div>
      <div class="p-4 md:p-0">
        <slot />
      </div>
    </div>
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
